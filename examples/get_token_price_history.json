{
  "operationId": "get_token_price_history",
  "method": "GET",
  "path": "/api/v2/chain/{chain}/token/{address}/price_history",
  "request": {
    "parameters": {
      "chain": "string",
      "address": "string",
      "start_time": "2024-01-01T00:00:00Z",
      "end_time": "2024-01-01T00:00:00Z",
      "bucket_size": "string"
    }
  },
  "response": {
    "200": {
      "prices": [
        {
          "time": "2024-01-01T00:00:00Z",
          "usd_price": 1
        }
      ]
    }
  }
}