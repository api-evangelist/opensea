{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensea.io/schemas/EventBase",
  "title": "EventBase",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string"
    },
    "event_timestamp": {
      "type": "integer",
      "format": "int64"
    },
    "transaction": {
      "type": "string"
    },
    "order_hash": {
      "type": "string"
    },
    "protocol_address": {
      "type": "string"
    },
    "chain": {
      "type": "string"
    },
    "payment": {
      "$ref": "#/components/schemas/Payment"
    }
  },
  "required": [
    "chain",
    "event_timestamp",
    "event_type"
  ]
}