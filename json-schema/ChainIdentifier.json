    "zora",
    "arbitrum",
    "sei",
    "avalanche",
    "polygon",
    "optimism",
    "ape_chain",
    "flow",
    "b3",
    "soneium",
    "ronin",
    "bera_chain",
    "solana",
    "shape",
    "unichain",
    "gunzilla",
    "abstract",
    "animechain",
    "hyperevm",
    "somnia",
    "monad",
    "hyperliquid",
    "megaeth",
    "ink"
  ],
  "example": "ethereum"
}